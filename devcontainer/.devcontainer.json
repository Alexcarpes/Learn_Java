{
  "name": "Java Terminal Environment",
  "image": "mcr.microsoft.com/devcontainers/java:21-bullseye",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "java --version"
}
